# Add System Message for exiting the game
@@ _startup_ps4.scs
	    Wait 1
+       KeyboardOnJump03 60, 1, @label(flag_on_jump)
	    Jump 1
+	@label(flag_on_jump):
+        FlagOnJump 1223, @label(call_rl)
+	     CallRL 313, @ra(first_sysmes)
+   *@ra(first_sysmes):
+       SystemMesInit 1
+       SystemMesSetMesScx 1, 107
+       SystemMesSetMesScx 1, 108
+       SystemMesSetSelScx 1, 109
+       SystemMesSetSelScx 1, 110
+       SystemMesInit2 1, 1
+       SystemMesFadeIn 1
+       SystemMesMain 1
+       SystemMesFadeOut 1
+       If $W(2128) == 0, @label(quit)
+       CallRL 314, @ra(first_go_loop)
+   *@ra(first_go_loop):
+       ResetFlag 3340
+       Jump 1
+   @label(call_rl):
+       CallRL 313, @ra(second_sysmes)
+   *@ra(second_sysmes):
+       SystemMesInit 1
+       SystemMesSetMesScx 1, 107
+       SystemMesSetMesScx 1, 108
+       SystemMesSetSelScx 1, 109
+       SystemMesSetSelScx 1, 110
+       SystemMesInit2 1, 1
+       SystemMesFadeIn 1
+       SystemMesMain 1
+       SystemMesFadeOut 1
+       If $W(2128) == 0, @label(quit)
+       CallRL 315, @ra(second_go_loop)
+   *@ra(second_go_loop):
+       ResetFlag 3340
+       Jump 1
+   @label(quit):
+       ExitGame
+       Halt
